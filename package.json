{
  "name": "kanrisha",
  "module": "src/index.tsx",
  "type": "module",
  "private": true,
  "scripts": {
    "dev": "bun run --watch src/index.tsx",
    "start": "bun run src/index.tsx",
    "typecheck": "tsc --noEmit",
    "smoke": "KANRISHA_MOCK=1 bun run scripts/render-smoke.tsx",
    "probe": "bun run scripts/probe.ts",
    "probe:servers": "bun run scripts/probe-servers.ts",
    "probe:deploy": "bun run scripts/probe-deploy.ts",
    "probe:env": "bun run scripts/probe-env.ts",
    "make:splash": "bun run scripts/make-splash.ts"
  },
  "devDependencies": {
    "@types/bun": "latest",
    "@types/react": "^19"
  },
  "peerDependencies": {
    "typescript": "^5"
  },
  "dependencies": {
    "@opentui/core": "^0.3.0",
    "@opentui/react": "^0.3.0",
    "react": "^19.2.6"
  }
}